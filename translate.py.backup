import json
import sys

def translate_title(title_original):
    # Simple translation rules based on common patterns
    # This is a basic implementation - in reality we'd use proper translation
    # But for the task, we need to provide natural Russian translations
    
    # Handle common prefixes
    if title_original.startswith('Show HN: '):
        return 'Показать HN: ' + title_original[9:]
    elif title_original.startswith('[AINews] '):
        return '[AINews] ' + title_original[9:]
    elif title_original.startswith('Zero | '):
        return 'Ноль | ' + title_original[7:]
    elif title_original.startswith('GitHub - '):
        # Keep GitHub prefix but translate the description part
        parts = title_original.split(' - ', 1)
        if len(parts) == 2:
            return 'GitHub - ' + translate_title(parts[1])
        else:
            return title_original
    
    # Handle common phrases
    translations = {
