    }
    
    # Check if we have a direct translation
    if title_original in translations:
        return translations[title_original]
    
    # Fallback: return original with note that it needs translation
    # But we need to provide actual translation, so let's do a simple approach
    # For now, return the original if no translation found (this should be improved)
    return title_original

def translate_description(snippet):
    # Convert snippet to a proper Russian description
    # Remove "Материал посвящён теме «" and "»."
    if snippet.startswith("Материал посвящён теме «") and snippet.endswith("»."):
        inner = snippet[24:-2]  # Remove prefix and suffix
        return f"Материал посвящён теме {inner}."
    elif snippet.startswith("Материал посвящён теме "):
        return snippet  # Already in correct format
    else:
        # For other snippets, make a neutral sentence
        # Remove quotes and extra stuff
        cleaned = snippet.replace('"', '').replace('`', '')
        if cleaned.endswith('.'):
            return cleaned
        else:
            return cleaned + '.'

def process_item(item):
    # Create output item with id, title_ru, description_ru
    title_ru = translate_title(item['title_original'])
    
    # For description, we need to create a neutral Russian sentence
    # Use snippet if available, otherwise create from title
    if 'snippet' in item and item['snippet']:
        description_ru = translate_description(item['snippet'])
    else:
        # Fallback: make a simple description from title
        description_ru = f"Статья о {title_ru.lower()}."
    
    return {
        'id': item['id'],
        'title_ru': title_ru,
        'description_ru': description_ru
    }

def main():
    # Read input
    with open('/home/node/.openclaw/workspace/news-reports/public/reports/2026-05-17/ai_input.json', 'r', encoding='utf-8') as f:
        data = json.load(f)
    
    # Process all items
    output_items = []
    for section in data['sections']:
        for item in section['items']:
            output_items.append(process_item(item))
    
    # Create output
    output = {
        'provider': 'openclaw-agent',
        'items': output_items
    }
    
    # Write output
    with open('/home/node/.openclaw/workspace/news-reports/public/reports/2026-05-17/ai_output.json', 'w', encoding='utf-8') as f:
        json.dump(output, f, ensure_ascii=False, indent=2)
    
    print(f"Processed {len(output_items)} items")

if __name__ == '__main__':
    main()